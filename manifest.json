{
  "manifest_version": 3,
  "name": "Productivity Hub",
  "version": "1.0.0",
  "description": "Your ultimate productivity companion - timer, notes, todos, and more!",
  "permissions": ["storage"],
  "icons": {
    "16": "/images/icon16.png",
    "48": "/images/icon48.png",
    "128": "/images/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Productivity Hub"
  }
}